generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agenda_psicologo {
  agenda_id              String    @id @default(uuid())
  status_disponibilidade Int?      @map("status_disponibilidade")
  isLogged               Int?      @map("is_logged")
  limiteAtendimento      Int       @map("limite_atendimento")
  psicologo_id           String    @unique(map: "psicologo_agenda") @map("psicologo_id")
  psicologo              Psicologo @relation("relacao_agenda", fields: [psicologo_id], references: [user_id], onDelete: Cascade)

  @@map("agendas")
}

model Avaliacao {
  star_id      String    @id @default(uuid())
  observacao   String    @db.VarChar(255)
  psicologo_id String    @map("psicologo_id")
  paciente_id  String    @map("paciente_id")
  paciente     Paciente  @relation("Avaliacao_feita", fields: [paciente_id], references: [user_id], onDelete: Cascade)
  psicologo    Psicologo @relation("Avaliacao_recebida", fields: [psicologo_id], references: [user_id], onDelete: Cascade)

  @@map("avaliacoes")
}

model Notificacao {
  not_id    String   @id @default(uuid())
  user_id   String
  mensagem  String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("notificacoes")
}

model Fila {
  fila_id     String   @id @default(uuid())
  statusFila  Int      @map("status_fila")
  entrada     DateTime @default(now())
  urgencia    Int
  triagem_id  String   @unique(map: "triagem")
  paciente_id String   @unique(map: "paciente")
  paciente    Paciente @relation(fields: [paciente_id], references: [user_id])
  triagem     Triagem  @relation(fields: [triagem_id], references: [id])

  @@map("filas")
}

model Logatividade {
  log_id   String   @id @default(uuid())
  user_id  String
  tipo     Int
  mensagem String
  data     DateTime @default(now())

  @@map("logs")
}

model Paciente {
  user_id   String      @id @map("user_id")
  idade     Int?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @default(now())
  telefone  String?
  avaliacao Avaliacao[] @relation("Avaliacao_feita")
  fila      Fila?
  user      User        @relation(fields: [user_id], references: [id])
  sessao    Sessao[]    @relation("SessoesPacientes")
  triagem   Triagem?

  @@map("pacientes")
}

model Psicologo {
  user_id       String            @id @map("user_id")
  bio           String?           @db.VarChar(500)
  createdAt     DateTime          @default(now())
  numero_ordem  String            @unique
  especialidade String?           @db.VarChar(255)
  updatedAt     DateTime          @default(now())
  status        Int               @default(2)
  agenda        Agenda_psicologo? @relation("relacao_agenda")
  avalicao      Avaliacao[]       @relation("Avaliacao_recebida")
  posts         Post[]
  user          User              @relation(fields: [user_id], references: [id])
  sessoes       Sessao[]          @relation("SessoesPsicologos")

  @@map("psicologos")
}

model Sessao {
  sessao_id    String    @id @default(uuid())
  status       Int       @default(0)
  inicio       DateTime  @default(now())
  fim          DateTime?
  psicologo_id String
  paciente_id  String
  paciente     Paciente  @relation("SessoesPacientes", fields: [paciente_id], references: [user_id])
  psicologo    Psicologo @relation("SessoesPsicologos", fields: [psicologo_id], references: [user_id])

  @@map("sessoes")
}

model Triagem {
  id          String   @id @default(uuid())
  score       Int
  urgencia    Int      @default(0)
  respostas   String
  createdAt   DateTime @default(now())
  paciente_id String   @unique
  fila        Fila?
  paciente    Paciente @relation(fields: [paciente_id], references: [user_id])

  @@map("triagens")
}

model User {
  id                 String              @id @default(uuid())
  nome               String              @db.VarChar(255)
  sobrenome          String              @db.VarChar(255)
  password           String
  photo              String?
  email              String              @unique(map: "email") @db.VarChar(255)
  role               Int
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @default(now())
  refreshToken       RefreshToken[]
  notificacoes       Notificacao[]
  paciente           Paciente?
  passwordResetCodes PasswordResetCode[]
  psicologo          Psicologo?

  @@map("users")
}

model PasswordResetCode {
  pass_id   String   @id @default(uuid())
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user_id   String
  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([code])
  @@map("password_codes")
}

model Post {
  post_id      String     @id @default(uuid())
  psicologo_id String?
  content      String
  photoUrl     String?
  likes        Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  hastags      String
  psicologo    Psicologo? @relation(fields: [psicologo_id], references: [user_id])

  @@map("posts")
}

model RefreshToken {
  token_id   String @id @default(uuid())
  expiresIn  Int
  refresh    String
  user_id    String
  user_agent String
  ip         String
  user       User   @relation(fields: [user_id], references: [id])
}
